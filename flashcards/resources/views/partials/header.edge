<header>
  <h1>
    <a href="/" style="text-decoration: none; color: inherit;">FlashCards</a>
  </h1>
  <div class="user-section">
    <span>Utilisateur : <strong>{{ auth.user.username }}</strong></span>

    <form action="{{ route('auth_logout') }}" method="POST">
      {{ csrfField() }}
      <button type="submit" class="btn btn-outline">
        Déco
      </button>
    </form>
  </div>
</header>
